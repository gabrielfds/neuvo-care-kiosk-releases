{
  "name": "neuvo-care-kiosk",
  "version": "0.4.4",
  "description": "Neuvo Care Kiosk — app nativo Windows com NFC e câmera",
  "main": "src/main.js",
  "private": true,
  "author": "Neuvo",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "dist": "electron-builder --win nsis --publish never",
    "release": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "nfc-pcsc": "^0.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "br.com.neuvo.care.kioskbridge",
    "productName": "Neuvo Care Kiosk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "publisherName": "Neuvo",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Neuvo Care Kiosk",
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "gabrielfds",
      "repo": "neuvo-care-kiosk-releases",
      "releaseType": "release"
    },
    "asarUnpack": [
      "**/*.node"
    ]
  }
}
