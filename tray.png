name: Build Neuvo Care Kiosk Bridge

on:
  workflow_dispatch:
  push:
    branches:
      - feature/neuvo-care-kiosk-bridge
    paths:
      - 'kiosk-bridge/**'
      - '.github/workflows/neuvo-care-kiosk-bridge-build.yml'

permissions:
  contents: read

defaults:
  run:
    working-directory: kiosk-bridge

jobs:
  build-windows:
    runs-on: windows-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Setup Python for node-gyp
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install ImageMagick
        shell: powershell
        run: choco install imagemagick -y --no-progress

      - name: Generate Windows icon
        shell: powershell
        run: |
          magick assets/icon.svg -resize 256x256 assets/icon.png
          magick assets/icon.png assets/icon.ico

      - name: Install dependencies
        shell: powershell
        run: |
          npm config set python "$env:pythonLocation\python.exe"
          npm install

      - name: Build installer
        shell: powershell
        env:
          CSC_IDENTITY_AUTO_DISCOVERY: false
        run: npm run dist

      - name: Upload installer artifact
        uses: actions/upload-artifact@v4
        with:
          name: neuvo-care-kiosk-bridge-windows
          path: kiosk-bridge/dist/*
